#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE' >&2
Usage: change-video-speed SPEED INPUT OUTPUT

Examples:
  change-video-speed 2 input.mp4 output.mp4      # 2x faster
  change-video-speed 1.5 input.mp4 output.mp4    # 1.5x faster
  change-video-speed 0.5 input.mp4 output.mp4    # half speed
USAGE
}

if [[ $# -ne 3 ]]; then
  usage
  exit 2
fi

speed=$1
input=$2
output=$3

if ! command -v ffmpeg >/dev/null 2>&1; then
  echo "Error: ffmpeg is required but was not found in PATH." >&2
  exit 1
fi

if ! command -v ffprobe >/dev/null 2>&1; then
  echo "Error: ffprobe is required but was not found in PATH." >&2
  exit 1
fi

if [[ ! -f "$input" ]]; then
  echo "Error: input file does not exist: $input" >&2
  exit 1
fi

if ! awk -v s="$speed" 'BEGIN { exit !(s ~ /^[0-9]+([.][0-9]+)?$/ && s > 0) }'; then
  echo "Error: SPEED must be a positive number, e.g. 2, 1.5, or 0.5" >&2
  exit 2
fi

# Build an audio tempo filter chain. atempo is most compatible in the 0.5..2.0 range,
# so large speed changes are split across multiple atempo filters.
build_atempo_chain() {
  awk -v speed="$1" 'BEGIN {
    remaining = speed + 0
    chain = ""

    while (remaining > 2.0) {
      chain = chain (chain ? "," : "") "atempo=2.0"
      remaining /= 2.0
    }

    while (remaining < 0.5) {
      chain = chain (chain ? "," : "") "atempo=0.5"
      remaining /= 0.5
    }

    chain = chain (chain ? "," : "") sprintf("atempo=%.10g", remaining)
    print chain
  }'
}

has_audio=false
if ffprobe -v error -select_streams a:0 -show_entries stream=index -of csv=p=0 "$input" | grep -q .; then
  has_audio=true
fi

if [[ "$has_audio" == true ]]; then
  atempo_chain=$(build_atempo_chain "$speed")
  ffmpeg -i "$input" \
    -filter_complex "[0:v]setpts=PTS/${speed}[v];[0:a]${atempo_chain}[a]" \
    -map "[v]" -map "[a]" \
    "$output"
else
  ffmpeg -i "$input" \
    -vf "setpts=PTS/${speed}" \
    "$output"
fi
